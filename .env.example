# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (LLM + Whisper)
OPENAI_API_KEY=sk-your-openai-key

# Google Cloud (Vision OCR)
GOOGLE_CLOUD_API_KEY=your-google-cloud-key

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# RevenueCat
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# PayPal Subscriptions
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
PAYPAL_MODE=sandbox
# IDs de los planes creados en dashboard.paypal.com → Products & Plans
NEXT_PUBLIC_PAYPAL_MONTHLY_PLAN_ID=P-XXXXXXXXX
NEXT_PUBLIC_PAYPAL_ANNUAL_PLAN_ID=P-XXXXXXXXX

# Push Notification Security (optional, for admin panel calls to send-push)
PUSH_SECRET=a-random-secret-for-push-api

# App Config
DEFAULT_CURRENCY=UYU
AI_MONTHLY_QUOTA_FREE=50
AI_MONTHLY_QUOTA_PRO=500
NEXT_PUBLIC_APP_URL=https://app.flowmind.ai
